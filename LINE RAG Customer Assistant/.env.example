# ======================================================================
# MooM HoM LINE RAG Assistant — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# This file (.env.example) holds ONLY placeholders and is safe to commit.
# Stack: Pinecone + OpenRouter + sentence-transformers
# ======================================================================

# --- OpenRouter (LLM) ---------------------------------------------------
# Get a key at https://openrouter.ai/keys (OpenAI-compatible API).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Reliable paid (pennies): openai/gpt-4o-mini. Free models end in ":free"
# (availability rotates; verify at the /api/v1/models endpoint).
LLM_MODEL=openai/gpt-4o-mini

# --- Pinecone (vector DB) ----------------------------------------------
# Get a free key at https://app.pinecone.io  (Starter plan is free)
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=moomhom-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=moomhom

# --- Embeddings (local, free) ------------------------------------------
# multilingual-e5 handles Thai well. base=768 dims, small=384 dims.
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# --- Retrieval settings -------------------------------------------------
TOP_K=4
CHUNK_SIZE=600
CHUNK_OVERLAP=80
SCORE_THRESHOLD=0.80          # cosine similarity for e5 sits high; tune with eval

# --- LINE Messaging API -------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=your-long-lived-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# --- Human handoff ------------------------------------------------------
# When a user sends a handoff trigger, the bot goes silent for this many hours
# so a human admin can take over in LINE, then re-enables automatically.
HANDOFF_HOURS=3
HANDOFF_TRIGGERS=talk to human,talk to a human,talk to agent,คุยกับแอดมิน,ขอคุยกับแอดมิน,คุยกับคน,ติดต่อแอดมิน,คุยกับเจ้าหน้าที่
RESUME_TRIGGERS=talk to bot,คุยกับบอท,เปิดบอท,คุยกับน้องหอม
HANDOFF_NOTIFY_ON_RESUME=true

# --- App ----------------------------------------------------------------
APP_ENV=local            # local | production
LOG_LEVEL=INFO
ASSISTANT_LANGUAGE=th
